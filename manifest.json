{
  "manifest_version": 3,
  "name": "Glossy",
  "version": "1.0.1",
  "description": "Browser extension to define words on selection",
  "icons": {
    "32": "images/icon.png",
    "64": "images/icon@2x.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "glossy@d_bud",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [],
  "background": {
    "scripts": [
      "dist/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "fonts/*.woff2"
      ]
    }
  ]
}
